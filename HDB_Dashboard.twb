      <aliases enabled='yes' />
      <column caption='Price_category' datatype='string' name='[Calculation_1807662785671168]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [resale_price] &lt; 100000 THEN &quot;Low&quot;&#13;&#10;ELSEIF [resale_price] &gt; 100000 and [resale_price] &lt;= 300000 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Luxury&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Price per HDB ID' datatype='real' name='[Calculation_1807662787076097]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [resale_identifier] : AVG([resale_price]) }' />
      </column>
